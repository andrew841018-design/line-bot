# 本檔僅供本機參考。實際請 `cp .env.example .env` 後填入下列三個值。

# ── LINE Messaging API（2 個值）──────────────────────────────────────────
# 從 https://developers.line.biz/console/ 拿（用既有的 LINE Official Account 即可）：
#   Basic settings  分頁 → Channel secret
#   Messaging API   分頁 → Channel access token (long-lived) → Issue
# 同頁記得設定：Auto-reply = OFF、Webhooks = ON、Allow bot to join group chats = ON
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ── Gemini（1 個值，免費）─────────────────────────────────────────────────
# 從 https://aistudio.google.com/app/apikey 按 Create API key 拿
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── SQLite（本地檔案路徑，相對於 line_bot/，不改也行）──────────────────
SQLITE_PATH=line_bot.db

# ── 鎖定單一群組（Q6=B）──────────────────────────────────────────────────
# 空字串 = 尚未鎖定，此時 bot 只會 log 收到的 group_id 給你抓
# 抓到後填進這裡再重啟
ALLOWED_GROUP_ID=

# ── Bot 行為 ──────────────────────────────────────────────────────────────
CONTEXT_ROUNDS=15
FACT_EXTRACT_EVERY=10
MAX_FACTS_IN_PROMPT=20
