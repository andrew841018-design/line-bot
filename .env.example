# 本檔僅供本機參考。Fly.io 正式環境用 `flyctl secrets set` 注入，不讀 .env。

# ── LINE Messaging API ────────────────────────────────────────────────────
# 從 https://developers.line.biz/console/ 拿：
#   Basic settings 分頁 → Channel secret
#   Messaging API 分頁 → Channel access token (long-lived) → Issue
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ── Gemini ────────────────────────────────────────────────────────────────
# 從 https://aistudio.google.com/app/apikey 拿
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Upstash Redis（Free Tier）────────────────────────────────────────────
# 從 https://console.upstash.com/ 建立 database 後，在 "REST API" 或
# "Details" 頁面找 "Redis URL"，直接整串複製進來。格式：
#   rediss://default:<password>@<xxx>.upstash.io:6379
REDIS_URL=

# ── 鎖定單一群組（Q6=B）──────────────────────────────────────────────────
# 空字串 = 尚未鎖定，此時 bot 只會 log 收到的 group_id 給你抓
# 抓到後用 `flyctl secrets set ALLOWED_GROUP_ID=Cxxx` 再 `flyctl deploy`
ALLOWED_GROUP_ID=

# ── Bot 行為 ──────────────────────────────────────────────────────────────
CONTEXT_ROUNDS=15
FACT_EXTRACT_EVERY=10
MAX_FACTS_IN_PROMPT=20
